// GENERATE RUNTIME TYPE RETURNS

var aSeq : Sequence = Sequence {1,2.0,"letters",true};
aSeq.type.println("/*","*/aSeq;");
aSeq[0].type.println("/*","*/ aSeq[0];");
aSeq[1].type.println("/*","*/ aSeq[1];");
aSeq[2].type.println("/*","*/ aSeq[2];");
aSeq[3].type.println("/*","*/ aSeq[3];");

"".println();
aSeq.asSequence().type().println("/*","*/ aSeq.asSequence();");
aSeq.asSet().type().println("/*","*/ aSeq.asSet();");
aSeq.asBag().type().println("/*","*/ aSeq.asBag();");
aSeq.asOrderedSet().type().println("/*","*/ aSeq.asOrderedSet();");

"\n".println();
var aSet : Set = Set {1,2.0,"letters",true};
aSet.type.println("/*","*/aSet;");
aSet[0].type.println("/*","*/ aSet[0];");
aSet[1].type.println("/*","*/ aSet[1];");
aSet[2].type.println("/*","*/ aSet[2];");
aSet[3].type.println("/*","*/ aSet[3];");

"".println();
aSet.asSequence().type().println("/*","*/ aSet.asSequence();");
aSet.asSet().type().println("/*","*/ aSet.asSet();");
aSet.asBag().type().println("/*","*/ aSet.asBag();");
aSet.asOrderedSet().type().println("/*","*/ aSet.asOrderedSet();");

"\n".println();
var aBag : Bag = Bag {1,2.0,"letters",true};
aBag.type.println("/*","*/aBag;");
aBag[0].type.println("/*","*/ aBag[0];");
aBag[1].type.println("/*","*/ aBag[1];");
aBag[2].type.println("/*","*/ aBag[2];");
aBag[3].type.println("/*","*/ aBag[3];");

"".println();
aBag.asSequence().type().println("/*","*/ aBag.asSequence();");
aBag.asSet().type().println("/*","*/ aBag.asSet();");
aBag.asBag().type().println("/*","*/ aBag.asSeqasBaguence();");
aBag.asOrderedSet().type().println("/*","*/ aBag.asOrderedSet();");

"\n".println();
var aOrderedSet : OrderedSet = OrderedSet {1,2.0,"letters",true};
aOrderedSet.type.println("/*","*/aOrderedSet;");
aOrderedSet[0].type.println("/*","*/ aOrderedSet[0];");
aOrderedSet[1].type.println("/*","*/ aOrderedSet[1];");
aOrderedSet[2].type.println("/*","*/ aOrderedSet[2];");
aOrderedSet[3].type.println("/*","*/ aOrderedSet[3];");

"".println();
aOrderedSet.asSequence().type().println("/*","*/ aOrderedSet.asSequence();");
aOrderedSet.asSet().type().println("/*","*/ aOrderedSet.asSet();");
aOrderedSet.asBag().type().println("/*","*/ aOrderedSet.asBag();");
aOrderedSet.asOrderedSet().type().println("/*","*/ aOrderedSet.asOrderedSet();");

